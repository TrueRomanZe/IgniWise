# IgniWise - Variables de Entorno
# Copia este archivo como .env y rellena tus API keys

# OpenWeatherMap API (OBLIGATORIO)
# Obtén tu key gratis en: https://openweathermap.org/api
OPENWEATHER_API_KEY=tu_api_key_aqui

# AEMET API (OPCIONAL pero recomendado)
# Obtén tu key gratis en: https://opendata.aemet.es/centrodedescargas/altaUsuario
AEMET_API_KEY=tu_api_key_aqui

# Zenodo URLs (actualizar después de publicar dataset)
ZENODO_DATASET_URL=https://zenodo.org/record/XXXXXXX/files/training_data.csv
ZENODO_MODEL_URL=https://zenodo.org/record/XXXXXXX/files/random_forest_v1.pkl
ZENODO_GEODATA_URL=https://zenodo.org/record/XXXXXXX/files/provincias_geo.geojson

# Configuración del Modelo
RF_N_ESTIMATORS=200
RF_MAX_DEPTH=15
RANDOM_SEED=42

# Configuración de Predicciones
FORECAST_DAYS=7
CONFIDENCE_THRESHOLD=0.75

# Configuración de Automatización
UPDATE_FREQUENCY_HOURS=6
RETRAIN_FREQUENCY_HOURS=24

# Logging
LOG_LEVEL=INFO
